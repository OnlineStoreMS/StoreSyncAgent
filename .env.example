# 复制为 .env 后填写（.env 不会提交到 Git）

# 所有账号共用密码（config.yaml 里 accounts.password 留空时生效）
KDZS_PASSWORD=

# 多账号时可按 ID 单独配置（优先级高于 KDZS_PASSWORD）
# 环境变量名规则：KDZS_ACCOUNT_{账号ID大写}_PASSWORD
# 例如账号 id 为 account_1 → KDZS_ACCOUNT_ACCOUNT_1_PASSWORD
# KDZS_ACCOUNT_ACCOUNT_1_PASSWORD=
# KDZS_ACCOUNT_ACCOUNT_2_PASSWORD=

# 对外端口（可选）
# PORT=8097
