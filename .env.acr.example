# ACR 拉取部署：cp .env.acr.example .env

# --- 阿里云 ACR ---
ALIYUN_ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ALIYUN_ACR_NAMESPACE=你的命名空间
ALIYUN_ACR_USER=你的ACR用户名
ALIYUN_ACR_PASSWORD=你的ACR密码
ACR_IMAGE_PREFIX=registry.cn-hangzhou.aliyuncs.com/你的命名空间
IMAGE_TAG=latest

# --- 端口 ---
API_PORT=8097
WEB_PORT=5178

# --- 快递助手密码（config.yaml 中 password 留空）---
KDZS_PASSWORD=
# KDZS_ACCOUNT_ACCOUNT_1_PASSWORD=
# KDZS_ACCOUNT_ACCOUNT_2_PASSWORD=
